{#
  Composant : footer Facebook + copyright
  Usage :
    {% from "composants/footer.njk" import footer_bloc %}
    {{ footer_bloc() }}
    {{ footer_bloc(label="Suivre l'aventure BFF", delay="1s") }}

  Paramètres :
    label     (str)  — Texte du bouton Facebook, défaut "Suivre Bridge & Flow Folk"
    copyright (str)  — Texte copyright, défaut valeur BFF
    delay     (str)  — Animation-delay, défaut "1.2s"
    fb_url    (str)  — URL Facebook, défaut page BFF
#}

{% macro footer_bloc(
  label="Suivre Bridge &amp; Flow Folk",
  copyright="© 2026 Bridge &amp; Flow Folk · Nogent-le-Roi (28) · 06 18 29 18 73",
  delay="1.2s",
  fb_url="https://www.facebook.com/people/Bridge-Flow-Folk-BFF/61587252715739/"
) %}
<div style="text-align:center;opacity:0;animation:glisser-haut 0.8s ease forwards {{ delay }};">
  <a class="fb-lien" href="{{ fb_url }}" target="_blank" rel="noopener noreferrer">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
      <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
    </svg>
    {{ label }}
  </a>
  <footer>{{ copyright }}</footer>
</div>
{% endmacro %}
