{#
  ════════════════════════════════════════════════════════════════
  Composant : galerie-inline (grille photos + lightbox)
  ════════════════════════════════════════════════════════════════
  Usage :
    {% from "composants/galerie-inline.njk" import galerie_inline %}
    {{ galerie_inline(photos, dossier="/Salon2/photos/") }}

  Structure YAML attendue :
    photos_section:
      - nom: "atelier-yoga.jpg"
        alt: "Atelier yoga parents-enfants"
      - nom: "stand-sophrologie.jpg"
        alt: "Stand sophrologie"

  Paramètres :
    photos     (list)  — liste {nom, alt}
    dossier    (str)   — chemin public des photos
    colonnes   (int)   — 2 | 3 (défaut) | 4
    id_galerie (str)   — identifiant unique si plusieurs galeries sur la page
#}

{% macro galerie_inline(photos, dossier="/Salon2/photos/", colonnes=3, id_galerie="gl") %}

<div style="
  display:grid;
  grid-template-columns:repeat({{ colonnes }},1fr);
  gap:12px;
  margin-bottom:2rem;
">
  {% for photo in photos %}
  <div
    onclick="{{ id_galerie }}_ouvrirZoom({{ loop.index0 }})"
    role="button"
    tabindex="0"
    aria-label="Agrandir : {{ photo.alt }}"
    onkeydown="if(event.key==='Enter'){{ id_galerie }}_ouvrirZoom({{ loop.index0 }})"
    style="
      background:rgba(255,255,255,0.45);
      border:1px solid rgba(201,169,110,0.2);
      border-radius:12px;
      padding:8px;
      cursor:pointer;
      opacity:0;
      animation:glisser-haut 0.5s ease forwards {{ 0.3 + loop.index0 * 0.06 }}s;
      transition:transform 0.4s cubic-bezier(0.165,0.84,0.44,1), box-shadow 0.4s;
    "
    onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 12px 30px rgba(160,132,92,0.22)';this.querySelector('img').style.transform='scale(1.1)'"
    onmouseout="this.style.transform='';this.style.boxShadow='';this.querySelector('img').style.transform=''"
  >
    <div style="aspect-ratio:1/1;overflow:hidden;border-radius:8px;">
      <img
        src="{{ dossier }}{{ photo.nom }}"
        alt="{{ photo.alt }}"
        loading="lazy"
        style="width:100%;height:100%;object-fit:cover;transition:transform 0.6s cubic-bezier(0.165,0.84,0.44,1);"
      />
    </div>
  </div>
  {% endfor %}
</div>

(Lightbox dédiée à cette instance)
<div id="{{ id_galerie }}-lightbox" onclick="{{ id_galerie }}_fermerZoom()" style="
  position:fixed;inset:0;
  background:rgba(15,15,20,0.97);
  backdrop-filter:blur(15px);
  display:none;flex-direction:column;
  justify-content:center;align-items:center;
  z-index:10000;user-select:none;
">
  <div style="position:relative;max-width:90%;max-height:80vh;display:flex;align-items:center;justify-content:center;">
    <button onclick="{{ id_galerie }}_fermerZoom()" aria-label="Fermer" style="position:absolute;top:-55px;right:0;background:none;border:none;color:white;font-size:2.5rem;cursor:pointer;opacity:0.7;transition:opacity 0.2s,color 0.2s;" onmouseover="this.style.opacity='1';this.style.color='var(--or)'" onmouseout="this.style.opacity='0.7';this.style.color='white'">&times;</button>
    <button onclick="{{ id_galerie }}_prev(event)" aria-label="Précédent" style="position:absolute;left:-75px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.08);color:white;border:none;width:56px;height:56px;border-radius:50%;font-size:1.6rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.25s,color 0.25s;" onmouseover="this.style.background='var(--or)';this.style.color='var(--nuit)'" onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.color='white'">&#10094;</button>
    <img id="{{ id_galerie }}-img" src="" alt="" style="max-width:100%;max-height:80vh;object-fit:contain;border-radius:4px;box-shadow:0 0 50px rgba(0,0,0,0.8);animation:zoomDouce 0.35s ease;" />
    <button onclick="{{ id_galerie }}_next(event)" aria-label="Suivant" style="position:absolute;right:-75px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.08);color:white;border:none;width:56px;height:56px;border-radius:50%;font-size:1.6rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.25s,color 0.25s;" onmouseover="this.style.background='var(--or)';this.style.color='var(--nuit)'" onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.color='white'">&#10095;</button>
  </div>
  <div id="{{ id_galerie }}-compteur" style="margin-top:22px;color:rgba(255,255,255,0.55);font-family:'Josefin Sans',sans-serif;letter-spacing:3px;font-size:0.85rem;"></div>
</div>

<script>
(function() {
  var photos  = [
    {% for p in photos %}{ src:"{{ dossier }}{{ p.nom }}", alt:"{{ p.alt }}" }{{ "," if not loop.last }}{% endfor %}
  ];
  var idx     = 0;
  var lb      = document.getElementById('{{ id_galerie }}-lightbox');
  var imgEl   = document.getElementById('{{ id_galerie }}-img');
  var cptEl   = document.getElementById('{{ id_galerie }}-compteur');

  function maj() {
    imgEl.src = photos[idx].src;
    imgEl.alt = photos[idx].alt;
    cptEl.textContent = (idx + 1) + ' / ' + photos.length;
  }

  window['{{ id_galerie }}_ouvrirZoom'] = function(i) {
    idx = i; maj();
    lb.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  };
  window['{{ id_galerie }}_fermerZoom'] = function() {
    lb.style.display = 'none';
    document.body.style.overflow = '';
  };
  window['{{ id_galerie }}_next'] = function(e) {
    e.stopPropagation();
    idx = (idx + 1) % photos.length; maj();
  };
  window['{{ id_galerie }}_prev'] = function(e) {
    e.stopPropagation();
    idx = (idx - 1 + photos.length) % photos.length; maj();
  };

  document.addEventListener('keydown', function(e) {
    if (lb.style.display !== 'flex') return;
    if (e.key === 'ArrowRight') { idx = (idx+1)%photos.length; maj(); }
    if (e.key === 'ArrowLeft')  { idx = (idx-1+photos.length)%photos.length; maj(); }
    if (e.key === 'Escape')     { window['{{ id_galerie }}_fermerZoom'](); }
  });
})();
</script>

<style>
  @keyframes zoomDouce { from { opacity:0; transform:scale(0.92); } to { opacity:1; transform:scale(1); } }
  @media(max-width:600px) {
    #{{ id_galerie }}-lightbox button[style*="left:-75px"] { left:-45px; width:42px; height:42px; font-size:1.2rem; }
    #{{ id_galerie }}-lightbox button[style*="right:-75px"] { right:-45px; width:42px; height:42px; font-size:1.2rem; }
  }
</style>
{% endmacro %}
