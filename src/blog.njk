---
layout: base.njk
permalink: /blog/

title: "Actualités — Bridge & Flow Folk"
description: "Suivez les actualités de Bridge & Flow Folk : nouveautés, coulisses de l'organisation, annonces."

hero:
  tag:       "Bridge & Flow Folk · Notre fil d'actu"
  titre:     "Actualités"
  sousTitre: "Les dernières nouvelles de l'association"
---

{% from "composants/sep.njk"    import sep %}
{% from "composants/footer.njk" import footer_bloc %}

<style>
.articles-liste { margin-bottom: 3rem; }
.article-carte {
  background: rgba(255,255,255,0.55);
  border: 1px solid rgba(201,169,110,0.3);
  border-radius: 16px; overflow: hidden;
  backdrop-filter: blur(8px);
  margin-bottom: 1.2rem;
  opacity: 0; animation: glisser-haut 0.6s ease forwards;
  transition: transform 0.3s, box-shadow 0.3s;
  position: relative;
  text-decoration: none; color: inherit;
  display: block;
}
.article-carte:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 40px rgba(160,132,92,0.18);
}
.article-corps { padding: 1.5rem 1.8rem; }
.article-meta { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.6rem; }
.article-date { font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--terre); }
.article-categorie {
  font-size: 0.55rem; letter-spacing: 0.15em;
  text-transform: uppercase; padding: 0.2rem 0.7rem;
  border-radius: 100px; border: 1px solid rgba(201,169,110,0.35);
  color: var(--or); background: rgba(201,169,110,0.1);
}
.article-titre {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 600; font-size: 1.35rem;
  color: var(--nuit); margin-bottom: 0.5rem; line-height: 1.3;
}
.article-extrait { font-size: 0.75rem; color: var(--terre); line-height: 1.65; }
.article-lire {
  display: inline-flex; align-items: center; gap: 0.4rem;
  margin-top: 0.8rem; font-size: 0.62rem;
  letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--sauge);
}
.footer-bloc { text-align: center; opacity: 0; animation: glisser-haut 0.8s ease forwards 1.5s; }
</style>

<div class="hero anime" style="animation-delay:0.2s">
  <span class="hero-tag">{{ hero.tag }}</span>
  <h1>{{ hero.titre }}</h1>
  <p class="hero-sub">{{ hero.sousTitre }}</p>
</div>

{{ sep() }}

<div class="articles-liste">
  {% set articles = collections.articles | sort(attribute="data.date") | reverse %}
  {% if articles | length %}
    {% for article in articles %}
    <a href="{{ article.url | url }}" class="article-carte" style="animation-delay:{{ 0.4 + loop.index0 * 0.1 }}s">
      <div style="height:3px;background:linear-gradient(to right,var(--sauge),var(--or),var(--lotus));"></div>
      <div class="article-corps">
        <div class="article-meta">
          <span class="article-date">{{ article.data.date | date("DD MMM YYYY") }}</span>
          {% if article.data.categorie %}
          <span class="article-categorie">{{ article.data.categorie }}</span>
          {% endif %}
        </div>
        <div class="article-titre">{{ article.data.title }}</div>
        {% if article.data.extrait %}
        <div class="article-extrait">{{ article.data.extrait }}</div>
        {% endif %}
        <span class="article-lire">Lire la suite &rarr;</span>
      </div>
    </a>
    {% endfor %}
  {% else %}
    <div style="text-align:center;padding:3rem;opacity:0.5;">
      <p style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-style:italic;color:var(--terre);">
        Les premi&egrave;res actualit&eacute;s arrivent bient&ocirc;t&hellip;
      </p>
    </div>
  {% endif %}
</div>

{{ footer_bloc() }}
