pageStyles: |
  .prix-badge { text-align: center; margin-bottom: 2rem; opacity: 0; animation: glisser-haut 0.7s ease forwards 0.4s; }
  .prix-gros { font-family: 'Cormorant Garamond', serif; font-size: clamp(3rem,10vw,5rem); font-weight: 300; color: var(--terre); }
  .prix-label { font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--terre); display: block; margin-top: 0.2rem; }
  .signes-grille { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; margin-bottom: 2rem; }
  .signe-carte { background: rgba(255,255,255,0.55); border: 1px solid rgba(201,169,110,0.3); border-radius: 14px; padding: 1.2rem 0.8rem; text-align: center; backdrop-filter: blur(8px); position: relative; overflow: hidden; transition: transform 0.3s, box-shadow 0.3s; opacity: 0; animation: glisser-haut 0.5s ease forwards; }
