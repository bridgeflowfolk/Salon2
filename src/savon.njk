  .signe-dates { font-size: 0.55rem; letter-spacing: 0.1em; color: rgba(44,44,58,0.5); margin-top: 0.2rem; display: block; }
  .signe-element { display: inline-block; margin-top: 0.5rem; font-size: 0.55rem; letter-spacing: 0.15em; text-transform: uppercase; padding: 0.2rem 0.6rem; border-radius: 100px; }
  .feu .signe-element   { background: rgba(224,112,64,0.15); color: #c05030; }
  .terre .signe-element { background: rgba(122,158,126,0.15); color: #5a8e5e; }
  .air .signe-element   { background: rgba(144,176,208,0.15); color: #5080a0; }
  .eau .signe-element   { background: rgba(96,128,176,0.15); color: #4060a0; }
  .artisanal-bloc { background: rgba(255,255,255,0.55); border: 1px solid rgba(201,169,110,0.3); border-radius: 16px; padding: 2rem; text-align: center; backdrop-filter: blur(8px); margin-bottom: 2rem; opacity: 0; animation: glisser-haut 0.7s ease forwards 1.5s; position: relative; overflow: hidden; }
  .artisanal-bloc::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(to right, var(--sauge), var(--or), var(--lotus)); }
  .artisanal-titre { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 300; color: var(--nuit); margin-bottom: 0.8rem; }
  .artisanal-desc { font-size: 0.75rem; letter-spacing: 0.05em; color: rgba(44,44,58,0.65); line-height: 1.8; }
  .footer-bloc { text-align: center; opacity: 0; animation: glisser-haut 0.8s ease forwards 1.6s; }
  @media(max-width: 480px) { .signes-grille { grid-template-columns: repeat(2,1fr); } }
---

{# Hero #}
<div class="hero anime" style="animation-delay:0.2s">
  <span class="hero-tag">{{ hero.tag }}</span>
  <h1>{{ hero.titre }}<br><em>{{ hero.titreEm }}</em></h1>
  <p class="hero-sub">{{ hero.sousTitre }}</p>
</div>

<div class="prix-badge">
  <div class="prix-gros">{{ prix.montant }}</div>
  <span class="prix-label">{{ prix.label }}</span>
</div>

<div class="sep">
  <div class="sep-l"></div><div class="sep-d"></div>
  <div class="sep-d" style="background:var(--sauge)"></div>
  <div class="sep-d"></div><div class="sep-r"></div>
</div>

{# Les 12 signes #}
<div class="signes-grille">
  {% for s in signes %}
  <div class="signe-carte {{ s.classe }}" style="animation-delay:{{ 0.5 + loop.index0 * 0.05 }}s">
    <span class="signe-symbole">{{ s.symbole }}</span>
    <div class="signe-nom">{{ s.nom }}</div>
    <span class="signe-dates">{{ s.dates }}</span>
    <span class="signe-element">{{ s.element }}</span>
  </div>
  {% endfor %}
</div>

<div class="artisanal-bloc">
  <div class="artisanal-titre">🧼 Savonnerie artisanale</div>
  <div class="artisanal-desc">
    Chaque savon est fabriqué à la main avec des ingrédients naturels.<br>
    Une création unique, personnalisée selon votre signe astrologique.<br>
    Idéal comme cadeau ou pour prendre soin de soi au quotidien.
  </div>
</div>

