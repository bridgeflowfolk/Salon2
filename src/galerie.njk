{% extends "layouts/base.njk" %}

{% block content %}

<section class="gallery">
  <div class="grid">
    {% for image in collections.galerie %}
      <div class="item">
        <img 
          src="{{ image.data.src }}" 
          alt="{{ image.data.alt }}" 
          loading="lazy"
          onclick="openViewer('{{ image.data.src }}', {{ loop.index0 }})"
        >
      </div>
    {% endfor %}
  </div>
</section>

<!-- Viewer plein écran -->
<div id="viewer" class="viewer hidden">
  <button class="close" onclick="closeViewer()">✕</button>

  <img id="viewer-img" src="" alt="">

  <div class="nav prev" onclick="prevImage()">❮</div>
  <div class="nav next" onclick="nextImage()">❯</div>

  <!-- Facebook -->
  <a id="facebook-link" href="#" target="_blank" class="facebook">
    <img src="/assets/facebook.png" alt="Facebook">
  </a>
</div>

<style>
/* GRID */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 10px;
}

.item img {
  width: 100%;
  height: 250px;
  object-fit: cover;
  cursor: pointer;
  border-radius: 8px;
}

/* VIEWER */
.viewer {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.viewer.hidden {
  display: none;
}

/* IMAGE LIMITÉE À L'ÉCRAN */
.viewer img {
  max-width: 100%;
  max-height: 100vh;
  object-fit: contain;
}

/* CROIX */
.close {
  position: absolute;
  top: 20px;
  right: 20px;
  font-size: 30px;
  background: none;
  border: none;
  color: white;
  cursor: pointer;
}

/* NAV */
.nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40px;
  color: white;
  cursor: pointer;
  user-select: none;
}

.prev { left: 20px; }
.next { right: 20px; }

/* FACEBOOK */
.facebook {
  position: absolute;
  bottom: 20px;
  right: 20px;
}

.facebook img {
  width: 40px;
  height: 40px;
}

/* MOBILE */
@media (max-width: 768px) {
  .nav {
    font-size: 28px;
  }

  .close {
    font-size: 24px;
  }
}
</style>

<script>
const images = [
  {% for image in collections.galerie %}
    {
      src: "{{ image.data.src }}",
      facebook: "{{ image.data.facebook or '' }}"
    }{% if not loop.last %},{% endif %}
  {% endfor %}
];

let currentIndex = 0;

function openViewer(src, index) {
  const viewer = document.getElementById("viewer");
  const img = document.getElementById("viewer-img");

  currentIndex = index;
  img.src = src;

  updateFacebook();

  viewer.classList.remove("hidden");

  // 🔥 Cache complètement le header/menu
  document.body.style.overflow = "hidden";
  document.querySelector("header")?.classList.add("hidden");
}

function closeViewer() {
  const viewer = document.getElementById("viewer");
  viewer.classList.add("hidden");

  document.body.style.overflow = "";
  document.querySelector("header")?.classList.remove("hidden");
}

function nextImage() {
  currentIndex = (currentIndex + 1) % images.length;
  updateViewer();
}

function prevImage() {
  currentIndex = (currentIndex - 1 + images.length) % images.length;
  updateViewer();
}

function updateViewer() {
  document.getElementById("viewer-img").src = images[currentIndex].src;
  updateFacebook();
}

function updateFacebook() {
  const link = document.getElementById("facebook-link");
  const fb = images[currentIndex].facebook;

  if (fb) {
    link.href = fb;
    link.style.display = "block";
  } else {
    link.style.display = "none";
  }
}

/* NAV CLAVIER */
document.addEventListener("keydown", (e) => {
  const viewer = document.getElementById("viewer");

  if (viewer.classList.contains("hidden")) return;

  if (e.key === "ArrowRight") nextImage();
  if (e.key === "ArrowLeft") prevImage();
  if (e.key === "Escape") closeViewer();
});
</script>

{% endblock %}
