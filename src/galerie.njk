---
layout: base.njk
permalink: /galerie/

title: "Galerie — Bien-Être et Créateurs 2026"
description: "Découvrez l'univers de nos créateurs en images. Galerie photos du salon de Bridge & Flow Folk à Nogent-le-Roi."

hero:
  tag:       "Souvenirs & Émotions · Bridge & Flow Folk"
  titre:     "La"
  titreEm:   "Galerie"
  sousTitre: "L'univers de nos créateurs à travers l'objectif"

pageStyles: |
  /* ── Grille de la Galerie ── */
  .galerie-grille {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 4rem;
  }

  .photo-carte {
    background: rgba(255, 255, 255, 0.45);
    border: 1px solid rgba(201, 169, 110, 0.2);
    border-radius: 15px;
    padding: 10px;
    backdrop-filter: blur(8px);
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    opacity: 0;
    animation: glisser-haut 0.6s ease forwards;
  }

  .img-container {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 10px;
    position: relative;
  }

  .img-container img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .photo-carte:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(160, 132, 92, 0.25);
    border-color: var(--or);
  }

  .photo-carte:hover .img-container img { transform: scale(1.1); }

  /* ── Lightbox (Lecteur Plein Écran) ── */
  #lightbox {
    position: fixed;
    top: 0; left: 0; 
    width: 100vw; height: 100vh;
    background: rgba(8, 8, 10, 0.98);
    backdrop-filter: blur(20px);
    display: none; /* Caché par défaut */
    z-index: 999999; /* AU-DESSUS DE TOUT (Nav bar incluse) */
    flex-direction: column;
    justify-content: center;
    align-items: center;
    user-select: none;
  }
  #lightbox.actif { display: flex; }

  /* Bouton Fermer - FIXE EN HAUT À DROITE */
  .lb-close {
    position: fixed;
    top: 30px;
    right: 30px;
    width: 60px;
    height: 60px;
    background: rgba(255, 255, 255, 0.1);
    color: white;
    border: none;
    border-radius: 50%;
    font-size: 3rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000000;
    transition: 0.3s;
    line-height: 0;
    padding-bottom: 8px; /* Centrage optique de la croix */
  }
  .lb-close:hover { background: var(--or); color: var(--nuit); transform: rotate(90deg); }

  .lb-contenu {
    position: relative;
    width: 90%;
    height: 75vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #imgZoom {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 0 60px rgba(0,0,0,0.5);
    animation: apparitionZoom 0.4s ease-out;
  }

  @keyframes apparitionZoom {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }

  /* Navigation Flèches */
  .lb-nav {
    position: absolute;
    top: 50%; transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.05);
    color: white; border: none;
    width: 70px; height: 70px;
    border-radius: 50%; font-size: 2rem;
    cursor: pointer; transition: 0.3s;
    display: flex; align-items: center; justify-content: center;
    z-index: 10;
  }
  .lb-nav:hover { background: var(--or); color: var(--nuit); }
  .lb-prev { left: -20px; }
  .lb-next { right: -20px; }

  .lb-compteur {
    position: fixed;
    bottom: 40px;
    color: rgba(255, 255, 255, 0.5);
    font-family: 'Josefin Sans', sans-serif;
    letter-spacing: 4px;
    font-size: 1.1rem;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .lb-nav { width: 50px; height: 50px; top: auto; bottom: 30px; transform: none; }
    .lb-prev { left: 20%; }
    .lb-next { right: 20%; }
    .lb-close { top: 20px; right: 20px; width: 50px; height: 50px; font-size: 2.2rem; }
    .lb-compteur { bottom: 100px; font-size: 0.9rem; }
    .lb-contenu { height: 60vh; width: 95%; }
  }
  @media (max-width: 480px) {
    .galerie-grille { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }
---

{# Utilisation de la variable globale définie dans src/_data/galerie.json #}
{% set g = galerie %}

<main>
  <div class="hero anime">
    <span class="hero-tag">{{ hero.tag }}</span>
    <h1>{{ hero.titre }} <em>{{ hero.titreEm }}</em></h1>
    <p class="hero-sub">{{ hero.sousTitre }}</p>
  </div>

  <div class="sep">
    <div class="sep-l"></div><div class="sep-d"></div><div class="sep-d" style="background:var(--sauge)"></div><div class="sep-d"></div><div class="sep-r"></div>
  </div>

  {# Conteneur injecté par le JS #}
  <div class="galerie-grille" id="conteneurGalerie"></div>

  <div style="text-align:center; margin-top: 3rem;" class="anime">
    <a class="fb-lien" href="https://www.facebook.com/people/Bridge-Flow-Folk-BFF/61587252715739/" target="_blank" rel="noopener">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
      Suivre l'aventure BFF
    </a>
    <footer style="margin-top:20px; opacity:0.5; font-size:0.8rem;">© 2026 Bridge &amp; Flow Folk</footer>
  </div>
</main>

{# Lightbox : Structure corrigée pour la visibilité #}
<div id="lightbox" onclick="fermerZoom()">
  <button class="lb-close" onclick="fermerZoom()">&times;</button>
  
  <div class="lb-contenu" onclick="event.stopPropagation()">
    <button class="lb-nav lb-prev" onclick="photoPrecedente(event)">&#10094;</button>
    <img id="imgZoom" src="" alt="Agrandissement" />
    <button class="lb-nav lb-next" onclick="photoSuivante(event)">&#10095;</button>
  </div>
  
  <div class="lb-compteur" id="compteur"></div>
</div>

<script>
  // 1. Injection sécurisée des données JSON d'Eleventy
  // On récupère g.photos (le tableau d'objets)
  const dataBrute = {{ g.photos | dump | safe }};
  
  // 2. Normalisation des chemins (gestion du slash initial pour la prod)
  const photosTab = dataBrute.map(p => {
    let chemin = p.nom;
    // Si le chemin ne commence pas par / et n'est pas une URL externe, on l'ajoute
    if (!chemin.startsWith('/') && !chemin.startsWith('http')) {
      chemin = '/' + chemin;
    }
    return {
      src: chemin,
      alt: p.alt || "Photo du Salon BFF"
    };
  });

  let indexActuel = 0;

  // 3. Remplissage de la grille HTML
  function genererGalerie() {
    const conteneur = document.getElementById('conteneurGalerie');
    if (!conteneur) return;
    
    if (photosTab.length === 0) {
      conteneur.innerHTML = "<p style='grid-column: 1/-1; text-align:center; opacity:0.6;'>Aucune photo pour le moment.</p>";
      return;
    }

    const fragment = document.createDocumentFragment();
    photosTab.forEach((photo, index) => {
      const carte = document.createElement('div');
      carte.className = 'photo-carte';
      carte.style.animationDelay = `${0.1 + (index * 0.05)}s`;
      carte.onclick = () => ouvrirZoom(index);
      
      carte.innerHTML = `
        <div class="img-container">
          <img src="${photo.src}" alt="${photo.alt}" loading="lazy">
        </div>
      `;
      fragment.appendChild(carte);
    });
    conteneur.appendChild(fragment);
  }

  // 4. Fonctions du Lecteur (Lightbox)
  function ouvrirZoom(index) {
    indexActuel = index;
    majLightbox();
    const lb = document.getElementById('lightbox');
    lb.classList.add('actif');
    document.body.style.overflow = "hidden"; // Empêche de scroller le site derrière
  }

  function majLightbox() {
    const img = document.getElementById('imgZoom');
    const cpt = document.getElementById('compteur');
    if (img) {
      img.src = photosTab[indexActuel].src;
      img.alt = photosTab[indexActuel].alt;
    }
    if (cpt) {
      cpt.innerText = (indexActuel + 1) + " / " + photosTab.length;
    }
  }

  function photoSuivante(e) {
    if (e) e.stopPropagation();
    indexActuel = (indexActuel + 1) % photosTab.length;
    majLightbox();
  }

  function photoPrecedente(e) {
    if (e) e.stopPropagation();
    indexActuel = (indexActuel - 1 + photosTab.length) % photosTab.length;
    majLightbox();
  }

  function fermerZoom() {
    const lb = document.getElementById('lightbox');
    lb.classList.remove('actif');
    document.body.style.overflow = ""; // Réactive le scroll
  }

  // Navigation clavier (Flèches et Echap)
  document.addEventListener('keydown', (e) => {
    const lb = document.getElementById('lightbox');
    if (!lb.classList.contains('actif')) return;
    
    if (e.key === "ArrowRight") photoSuivante(e);
    if (e.key === "ArrowLeft") photoPrecedente(e);
    if (e.key === "Escape") fermerZoom();
  });

  // Initialisation au chargement de la page
  window.addEventListener('load', genererGalerie);
</script>
