---
layout: base.njk
permalink: /galerie/

title: "Galerie — Bien-Être et Créateurs 2026"
description: "Découvrez l'univers de nos créateurs en images. Galerie photos du salon de Bridge & Flow Folk à Nogent-le-Roi."

hero:
  tag:       "Souvenirs & Émotions · Bridge & Flow Folk"
  titre:     "La"
  titreEm:   "Galerie"
  sousTitre: "L'univers de nos créateurs à travers l'objectif"

pageStyles: |
  .galerie-grille {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 4rem;
  }

  .photo-carte {
    background: rgba(255, 255, 255, 0.45);
    border: 1px solid rgba(201, 169, 110, 0.2);
    border-radius: 15px;
    padding: 10px;
    backdrop-filter: blur(8px);
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    opacity: 0;
    animation: glisser-haut 0.6s ease forwards;
  }

  .img-container {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 10px;
    position: relative;
  }

  .img-container img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .photo-carte:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(160, 132, 92, 0.25);
    border-color: var(--or);
    background: rgba(255, 255, 255, 0.7);
  }

  .photo-carte:hover .img-container img { transform: scale(1.12); }

  /* ── Lightbox (Lecteur) ── */
  #lightbox {
    position: fixed; inset: 0;
    background: rgba(10, 10, 12, 0.98);
    backdrop-filter: blur(15px);
    display: none;
    z-index: 10000;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    user-select: none;
  }
  #lightbox.actif { display: flex; }

  .lb-contenu {
    position: relative;
    max-width: 90%;
    max-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #imgZoom {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 0 50px rgba(0,0,0,0.8);
    animation: zoomDouce 0.4s ease;
  }

  @keyframes zoomDouce {
    from { opacity: 0; transform: scale(0.95); }
    to   { opacity: 1; transform: scale(1); }
  }

  .lb-nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,0.08);
    color: white; border: none;
    width: 60px; height: 60px;
    border-radius: 50%; font-size: 1.8rem;
    cursor: pointer; transition: 0.3s;
    display: flex; align-items: center; justify-content: center;
    z-index: 10;
  }
  .lb-nav:hover { background: var(--or); color: var(--nuit); }
  .lb-prev { left: -80px; }
  .lb-next { right: -80px; }

  .lb-close {
    position: absolute; 
    top: -60px; 
    right: 0;
    color: white; 
    font-size: 3rem; 
    cursor: pointer;
    font-family: Arial, sans-serif; 
    line-height: 1;
    opacity: 0.7;
    background: none; 
    border: none;
    padding: 10px;
    z-index: 100;
  }
  .lb-close:hover { opacity: 1; color: var(--or); }

  .lb-compteur {
    margin-top: 25px;
    color: rgba(255,255,255,0.5);
    font-family: 'Josefin Sans', sans-serif;
    letter-spacing: 3px; font-size: 0.9rem;
  }

  @media(max-width: 850px) {
    .lb-nav { width: 50px; height: 50px; top: auto; bottom: -80px; transform: none; }
    .lb-prev { left: 25%; }
    .lb-next { right: 25%; }
    .lb-close { right: 0px; top: -60px; }
  }
  @media(max-width: 480px) {
    .galerie-grille { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }
---

{% set g = galerie %}

<main>
  {# Hero Section #}
  <div class="hero anime">
    <span class="hero-tag">{{ hero.tag }}</span>
    <h1>{{ hero.titre }} <em>{{ hero.titreEm }}</em></h1>
    <p class="hero-sub">{{ hero.sousTitre }}</p>
  </div>

  <div class="sep">
    <div class="sep-l"></div><div class="sep-d"></div><div class="sep-d" style="background:var(--sauge)"></div><div class="sep-d"></div><div class="sep-r"></div>
  </div>

  {# Grille #}
  <div class="galerie-grille" id="conteneurGalerie"></div>

  {# Footer #}
  <div style="text-align:center; margin-top: 3rem;" class="anime">
    <a class="fb-lien" href="https://www.facebook.com/people/Bridge-Flow-Folk-BFF/61587252715739/" target="_blank" rel="noopener">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
      Suivre l'aventure BFF
    </a>
    <footer style="margin-top:10px; opacity:0.6; font-size:0.9rem;">© 2026 Bridge &amp; Flow Folk · Nogent-le-Roi (28)</footer>
  </div>
</main>

{# Visionneuse #}
<div id="lightbox" onclick="fermerZoom()">
  <div class="lb-contenu" onclick="event.stopPropagation()">
    <button class="lb-close" onclick="fermerZoom()">&times;</button>
    <button class="lb-nav lb-prev" onclick="photoPrecedente(event)">&#10094;</button>
    <img id="imgZoom" src="" alt="Agrandissement" />
    <button class="lb-nav lb-next" onclick="photoSuivante(event)">&#10095;</button>
  </div>
  <div class="lb-compteur" id="compteur"></div>
</div>

<script>
  // 1. Injection des données depuis galerie.json
  const dataBrute = {{ g.photos | dump | safe }};
  
  // 2. Préparation des chemins (on s'assure que ça commence par / pour éviter les erreurs de dossier relatif)
  const photosTab = dataBrute.map(p => ({
    src: p.nom.startsWith('http') || p.nom.startsWith('/') ? p.nom : '/' + p.nom,
    alt: p.alt || "Photo du Salon"
  }));

  let indexActuel = 0;

  // 3. Génération de la grille
  function genererGalerie() {
    const conteneur = document.getElementById('conteneurGalerie');
    if (!conteneur) return;
    
    if (!photosTab.length) {
      conteneur.innerHTML = '<div class="galerie-vide"><p>Les photos arrivent bientôt…</p></div>';
      return;
    }

    const fragment = document.createDocumentFragment();
    photosTab.forEach((photo, index) => {
      const carte = document.createElement('div');
      carte.className = 'photo-carte';
      carte.style.animationDelay = `${0.2 + (index * 0.05)}s`;
      carte.onclick = () => ouvrirZoom(index);
      carte.innerHTML = `
        <div class="img-container">
          <img src="${photo.src}" alt="${photo.alt}" loading="lazy">
        </div>
      `;
      fragment.appendChild(carte);
    });
    conteneur.appendChild(fragment);
  }

  // 4. Logique Lightbox
  function ouvrirZoom(index) {
    indexActuel = index;
    majLightbox();
    document.getElementById('lightbox').classList.add('actif');
    document.body.style.overflow = "hidden"; // Stop scroll fond
  }

  function majLightbox() {
    const img = document.getElementById('imgZoom');
    const cpt = document.getElementById('compteur');
    if (img) {
      img.src = photosTab[indexActuel].src;
      img.alt = photosTab[indexActuel].alt;
    }
    if (cpt) cpt.innerText = `${indexActuel + 1} / ${photosTab.length}`;
  }

  function photoSuivante(e) {
    if (e) e.stopPropagation();
    indexActuel = (indexActuel + 1) % photosTab.length;
    majLightbox();
  }

  function photoPrecedente(e) {
    if (e) e.stopPropagation();
    indexActuel = (indexActuel - 1 + photosTab.length) % photosTab.length;
    majLightbox();
  }

  function fermerZoom() {
    document.getElementById('lightbox').classList.remove('actif');
    document.body.style.overflow = ""; // Relance scroll fond
  }

  // Navigation clavier
  document.addEventListener('keydown', (e) => {
    const lb = document.getElementById('lightbox');
    if (!lb || !lb.classList.contains('actif')) return;
    if (e.key === "ArrowRight") photoSuivante(e);
    if (e.key === "ArrowLeft") photoPrecedente(e);
    if (e.key === "Escape") fermerZoom();
  });

  window.addEventListener('load', genererGalerie);
</script>
