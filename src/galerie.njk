---
layout: base.njk
permalink: /galerie/

title: "Galerie — Bien-Être et Créateurs 2026"
description: "Découvrez l'univers de nos créateurs en images."

hero:
  tag:       "Souvenirs & Émotions · Bridge & Flow Folk"
  titre:     "La"
  titreEm:   "Galerie"
  sousTitre: "L'univers de nos créateurs à travers l'objectif"

pageStyles: |
  :root {
    --nav-height: 90px; /* ajuste si besoin */
  }

  /* ── Grille ── */
  .galerie-grille {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 4rem;
  }

  .photo-carte {
    background: rgba(255,255,255,0.45);
    border-radius: 15px;
    padding: 10px;
    cursor: pointer;
  }

  .img-container {
    aspect-ratio: 1/1;
    overflow: hidden;
    border-radius: 10px;
  }

  .img-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── LIGHTBOX (propre, proche de ton HTML) ── */
  #lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.95);
    display: none;
    z-index: 999999;

    /* 👉 correction du bug navbar */
    padding-top: var(--nav-height);

    display: none;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }

  #lightbox.actif {
    display: flex;
  }

  .lb-contenu {
    position: relative;
    max-width: 90%;
    max-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* 👉 COMME TON HTML */
  #imgZoom {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
  }

  /* CROIX */
  .lb-close {
    position: absolute;
    top: -50px;
    right: 0;
    color: white;
    font-size: 2.5rem;
    cursor: pointer;
  }

  /* NAV */
  .lb-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    color: white;
    border: none;
    font-size: 2rem;
    cursor: pointer;
  }

  .lb-prev { left: -80px; }
  .lb-next { right: -80px; }

  /* COMPTEUR */
  .lb-compteur {
    margin-top: 20px;
    color: rgba(255,255,255,0.6);
  }

  /* MOBILE */
  @media(max-width: 768px) {
    .lb-nav {
      top: auto;
      bottom: -60px;
      transform: none;
    }

    .lb-prev { left: 20%; }
    .lb-next { right: 20%; }
  }
---

{% set g = galerie %}

<main>
  <div class="hero">
    <span>{{ hero.tag }}</span>
    <h1>{{ hero.titre }} <em>{{ hero.titreEm }}</em></h1>
    <p>{{ hero.sousTitre }}</p>
  </div>

  <div class="galerie-grille" id="conteneurGalerie"></div>

  <!-- ✅ LIEN FACEBOOK RESTAURÉ -->
  <div style="text-align:center; margin-top: 3rem;">
    <a href="https://www.facebook.com/people/Bridge-Flow-Folk-BFF/61587252715739/" target="_blank">
      Suivre l'aventure BFF
    </a>
  </div>
</main>

<!-- LIGHTBOX -->
<div id="lightbox" onclick="fermerZoom()">
  <div class="lb-contenu" onclick="event.stopPropagation()">

    <span class="lb-close" onclick="fermerZoom()">&times;</span>

    <button class="lb-nav lb-prev" onclick="photoPrecedente(event)">‹</button>
    <img id="imgZoom" src="">
    <button class="lb-nav lb-next" onclick="photoSuivante(event)">›</button>

  </div>

  <div class="lb-compteur" id="compteur"></div>
</div>

<script>
  const dataBrute = {{ g.photos | dump | safe }};

  const photosTab = dataBrute.map(p => {
    let chemin = p.nom;
    if (!chemin.startsWith('/')) chemin = '/' + chemin;
    return { src: chemin };
  });

  let indexActuel = 0;

  function genererGalerie() {
    const conteneur = document.getElementById('conteneurGalerie');

    photosTab.forEach((photo, index) => {
      const div = document.createElement('div');
      div.className = 'photo-carte';
      div.onclick = () => ouvrirZoom(index);

      div.innerHTML = `
        <div class="img-container">
          <img src="${photo.src}" loading="lazy">
        </div>
      `;

      conteneur.appendChild(div);
    });
  }

  function ouvrirZoom(index) {
    indexActuel = index;
    maj();
    document.getElementById('lightbox').classList.add('actif');
  }

  function maj() {
    document.getElementById('imgZoom').src = photosTab[indexActuel].src;
    document.getElementById('compteur').innerText =
      (indexActuel + 1) + " / " + photosTab.length;
  }

  function photoSuivante(e) {
    e.stopPropagation();
    indexActuel = (indexActuel + 1) % photosTab.length;
    maj();
  }

  function photoPrecedente(e) {
    e.stopPropagation();
    indexActuel = (indexActuel - 1 + photosTab.length) % photosTab.length;
    maj();
  }

  function fermerZoom() {
    document.getElementById('lightbox').classList.remove('actif');
  }

  window.addEventListener('load', genererGalerie);
</script>
