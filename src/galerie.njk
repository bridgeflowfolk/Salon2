---
layout: base.njk
permalink: /galerie/

title: "Galerie — Bien-Être et Créateurs 2026"
description: "Découvrez l'univers de nos créateurs en images."

hero:
  tag:       "Souvenirs & Émotions · Bridge & Flow Folk"
  titre:     "La"
  titreEm:   "Galerie"
  sousTitre: "L'univers de nos créateurs à travers l'objectif"

pageStyles: |
  :root {
    --nav-height: 90px;
  }

  /* ── Grille ── */
  .galerie-grille {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 4rem;
  }

  .photo-carte {
    background: rgba(255,255,255,0.45);
    border: 1px solid rgba(201,169,110,0.2);
    border-radius: 15px;
    padding: 10px;
    backdrop-filter: blur(8px);
    cursor: pointer;
    transition: 0.5s;
    opacity: 0;
    animation: glisser-haut 0.6s ease forwards;
  }

  .img-container {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 10px;
  }

  .img-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s;
  }

  .photo-carte:hover {
    transform: translateY(-6px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
  }

  .photo-carte:hover img {
    transform: scale(1.08);
  }

  /* ── LIGHTBOX PRO ── */
  #lightbox {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100dvh;

    background: rgba(8,8,10,0.98);
    backdrop-filter: blur(20px);

    display: none;
    flex-direction: column;

    z-index: 999999;

    /* SAFE ZONE */
    padding-top: calc(var(--nav-height) + env(safe-area-inset-top));
    padding-bottom: env(safe-area-inset-bottom);

    box-sizing: border-box;
  }

  #lightbox.actif {
    display: flex;
  }

  .lb-contenu {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  #imgZoom {
    max-width: 95%;
    max-height: 100%;
    object-fit: contain;
    border-radius: 6px;
    box-shadow: 0 0 60px rgba(0,0,0,0.6);
  }

  /* CLOSE */
  .lb-close {
    position: fixed;
    top: calc(env(safe-area-inset-top) + 20px);
    right: 20px;

    width: 55px;
    height: 55px;

    background: rgba(255,255,255,0.1);
    color: white;

    border-radius: 50%;
    border: none;

    font-size: 2.2rem;

    display: flex;
    align-items: center;
    justify-content: center;

    cursor: pointer;
    z-index: 1000001;
  }

  /* NAV */
  .lb-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);

    width: 60px;
    height: 60px;

    border-radius: 50%;
    border: none;

    background: rgba(255,255,255,0.08);
    color: white;

    font-size: 2rem;

    display: flex;
    align-items: center;
    justify-content: center;

    cursor: pointer;
  }

  .lb-prev { left: 20px; }
  .lb-next { right: 20px; }

  /* COMPTEUR */
  .lb-compteur {
    position: absolute;
    bottom: calc(20px + env(safe-area-inset-bottom));
    width: 100%;
    text-align: center;
    color: rgba(255,255,255,0.6);
    font-family: 'Josefin Sans', sans-serif;
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .lb-nav {
      top: auto;
      bottom: 20px;
      transform: none;
      width: 50px;
      height: 50px;
    }

    .lb-prev { left: 25%; }
    .lb-next { right: 25%; }

    #imgZoom {
      max-width: 100%;
    }
  }
---

{% set g = galerie %}

<main>
  <div class="hero anime">
    <span class="hero-tag">{{ hero.tag }}</span>
    <h1>{{ hero.titre }} <em>{{ hero.titreEm }}</em></h1>
    <p class="hero-sub">{{ hero.sousTitre }}</p>
  </div>

  <div class="sep"></div>

  <div class="galerie-grille" id="conteneurGalerie"></div>
</main>

<!-- LIGHTBOX -->
<div id="lightbox" onclick="fermerZoom()">
  <button class="lb-close" onclick="fermerZoom()">&times;</button>

  <div class="lb-contenu" onclick="event.stopPropagation()">
    <button class="lb-nav lb-prev" onclick="photoPrecedente(event)">‹</button>
    <img id="imgZoom" src="" alt="">
    <button class="lb-nav lb-next" onclick="photoSuivante(event)">›</button>
  </div>

  <div class="lb-compteur" id="compteur"></div>
</div>

<script>
  const dataBrute = {{ g.photos | dump | safe }};

  const photosTab = dataBrute.map(p => {
    let chemin = p.nom;
    if (!chemin.startsWith('/') && !chemin.startsWith('http')) {
      chemin = '/' + chemin;
    }
    return {
      src: chemin,
      alt: p.alt || "Photo"
    };
  });

  let indexActuel = 0;

  function genererGalerie() {
    const conteneur = document.getElementById('conteneurGalerie');
    const fragment = document.createDocumentFragment();

    photosTab.forEach((photo, index) => {
      const carte = document.createElement('div');
      carte.className = 'photo-carte';
      carte.onclick = () => ouvrirZoom(index);

      carte.innerHTML = `
        <div class="img-container">
          <img src="${photo.src}" alt="${photo.alt}" loading="lazy">
        </div>
      `;

      fragment.appendChild(carte);
    });

    conteneur.appendChild(fragment);
  }

  function ouvrirZoom(index) {
    indexActuel = index;
    majLightbox();
    document.getElementById('lightbox').classList.add('actif');
    document.body.style.overflow = "hidden";
  }

  function majLightbox() {
    const img = document.getElementById('imgZoom');
    const cpt = document.getElementById('compteur');

    img.src = photosTab[indexActuel].src;
    img.alt = photosTab[indexActuel].alt;
    cpt.innerText = `${indexActuel + 1} / ${photosTab.length}`;
  }

  function photoSuivante(e) {
    e.stopPropagation();
    indexActuel = (indexActuel + 1) % photosTab.length;
    majLightbox();
  }

  function photoPrecedente(e) {
    e.stopPropagation();
    indexActuel = (indexActuel - 1 + photosTab.length) % photosTab.length;
    majLightbox();
  }

  function fermerZoom() {
    document.getElementById('lightbox').classList.remove('actif');
    document.body.style.overflow = "";
  }

  document.addEventListener('keydown', (e) => {
    const lb = document.getElementById('lightbox');
    if (!lb.classList.contains('actif')) return;

    if (e.key === "ArrowRight") photoSuivante(e);
    if (e.key === "ArrowLeft") photoPrecedente(e);
    if (e.key === "Escape") fermerZoom();
  });

  window.addEventListener('load', genererGalerie);

  /* AUTO NAV HEIGHT */
  const nav = document.querySelector('nav');
  if (nav) {
    document.documentElement.style.setProperty(
      '--nav-height',
      nav.offsetHeight + 'px'
    );
  }
</script>
