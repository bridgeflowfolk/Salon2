---
layout: base.njk
permalink: /galerie/

title: "Galerie — Bien-Être et Créateurs 2026"
description: "Découvrez l'univers de nos créateurs en images. Galerie photos du salon Bien-Être et Créateurs de Bridge & Flow Folk à Nogent-le-Roi."

hero:
  tag:       "Souvenirs & Émotions · Bridge & Flow Folk"
  titre:     "La"
  titreEm:   "Galerie"
  sousTitre: "L'univers de nos créateurs à travers l'objectif"

pageStyles: |
  /* ── Grille galerie ── */
  .galerie-grille {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 4rem;
  }

  .photo-carte {
    background: rgba(255, 255, 255, 0.45);
    border: 1px solid rgba(201, 169, 110, 0.2);
    border-radius: 15px;
    padding: 10px;
    backdrop-filter: blur(8px);
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    opacity: 0;
    animation: glisser-haut 0.6s ease forwards;
  }

  .img-container {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 10px;
    position: relative;
  }

  .img-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .photo-carte:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(160, 132, 92, 0.25);
    border-color: var(--or);
    background: rgba(255, 255, 255, 0.7);
  }

  .photo-carte:hover .img-container img {
    transform: scale(1.12);
  }

  /* ── Galerie vide ── */
  .galerie-vide {
    grid-column: 1 / -1;
    text-align: center;
    padding: 4rem 2rem;
    opacity: 0.55;
  }
  .galerie-vide p {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.2rem;
    color: var(--terre);
  }

  /* ── Lightbox ── */
  #lightbox {
    position: fixed; inset: 0;
    background: rgba(15, 15, 20, 0.98);
    backdrop-filter: blur(15px);
    display: none;
    z-index: 10000;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    user-select: none;
  }
  #lightbox.actif { display: flex; }

  .lb-contenu {
    position: relative;
    max-width: 90%;
    max-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #imgZoom {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 0 50px rgba(0,0,0,0.8);
    animation: zoomDouce 0.4s ease;
  }

  @keyframes zoomDouce {
    from { opacity: 0; transform: scale(0.9); }
    to   { opacity: 1; transform: scale(1); }
  }

  .lb-nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,0.08);
    color: white; border: none;
    width: 60px; height: 60px;
    border-radius: 50%; font-size: 1.8rem;
    cursor: pointer; transition: 0.3s;
    display: flex; align-items: center; justify-content: center;
  }
  .lb-nav:hover { background: var(--or); color: var(--nuit); }
  .lb-prev { left: -80px; }
  .lb-next { right: -80px; }

  .lb-close {
    position: absolute; top: -60px; right: 0;
    color: white; font-size: 2.5rem; cursor: pointer;
    font-family: 'Josefin Sans', sans-serif; opacity: 0.7;
    background: none; border: none;
  }
  .lb-close:hover { opacity: 1; color: var(--or); }

  .lb-compteur {
    margin-top: 25px;
    color: rgba(255,255,255,0.6);
    font-family: 'Josefin Sans', sans-serif;
    letter-spacing: 3px; font-size: 0.9rem;
  }

  .footer-bloc {
    text-align: center;
    opacity: 0; animation: glisser-haut 0.8s ease forwards 0.8s;
  }

  @media(max-width: 850px) {
    .lb-nav { width: 50px; height: 50px; top: auto; bottom: -70px; transform: none; }
    .lb-prev { left: 20%; }
    .lb-next { right: 20%; }
    .lb-close { right: 10px; top: -50px; }
  }
  @media(max-width: 480px) {
    .galerie-grille { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .photo-carte { padding: 5px; border-radius: 10px; }
  }
---

{# Les données viennent de src/_data/galerie.json — variable globale `galerie` #}
{% set g = galerie %}

{# Hero #}
<div class="hero anime">
  <span class="hero-tag">{{ hero.tag }}</span>
  <h1>{{ hero.titre }} <em>{{ hero.titreEm }}</em></h1>
  <p class="hero-sub">{{ hero.sousTitre }}</p>
</div>

<div class="sep">
  <div class="sep-l"></div>
  <div class="sep-d"></div>
  <div class="sep-d" style="background:var(--sauge)"></div>
  <div class="sep-d"></div>
  <div class="sep-r"></div>
</div>

{# Grille photos — données depuis galerie.json #}
<div class="galerie-grille" id="conteneurGalerie">
  {% if g.photos and g.photos.length %}
    {% for photo in g.photos %}
    <div class="photo-carte"
         style="animation-delay: {{ 0.2 + loop.index0 * 0.08 }}s"
         onclick="ouvrirZoom({{ loop.index0 }})"
         role="button"
         aria-label="Agrandir : {{ photo.alt }}">
      <div class="img-container">
        <img src="{{ "/" if not photo.nom.startsWith("/") }}{{ photo.nom }}"
             alt="{{ photo.alt }}"
             loading="lazy" />
      </div>
    </div>
    {% endfor %}
  {% else %}
    <div class="galerie-vide">
      <p>Les photos arrivent bientôt…</p>
    </div>
  {% endif %}
</div>

{# Footer #}
<div class="footer-bloc">
  <a class="fb-lien"
     href="https://www.facebook.com/people/Bridge-Flow-Folk-BFF/61587252715739/"
     target="_blank" rel="noopener noreferrer">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
      <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
    </svg>
    Suivre l'aventure BFF
  </a>
  <footer>© 2026 Bridge &amp; Flow Folk · Nogent-le-Roi (28)</footer>
</div>

{# Lightbox — structure identique à la version HTML de référence #}
<div id="lightbox">
  <div class="lb-contenu">
    <span class="lb-close">&times;</span>
    <button class="lb-nav lb-prev">&#10094;</button>
    <img id="imgZoom" src="" alt="Zoom" />
    <button class="lb-nav lb-next">&#10095;</button>
  </div>
  <div class="lb-compteur" id="compteur"></div>
</div>

{# JS — tableau injecté par 11ty au build depuis galerie.json #}
<script>
  // Tableau généré au build par 11ty
  const photosTab = [
    {% for photo in g.photos %}
    {
      src: "{{ "/" if not photo.nom.startsWith("/") }}{{ photo.nom }}",
      alt: {{ photo.alt | dump }}
    }{{ "," if not loop.last }}
    {% endfor %}
  ];

  const dossier = "";
  let indexActuel = 0;

  const lightbox  = document.getElementById("lightbox");
  const imgZoom   = document.getElementById("imgZoom");
  const compteur  = document.getElementById("compteur");
  const btnPrev   = lightbox.querySelector(".lb-prev");
  const btnNext   = lightbox.querySelector(".lb-next");
  const btnClose  = lightbox.querySelector(".lb-close");

  function majLightbox() {
    const p = photosTab[indexActuel];
    imgZoom.src = p.src;
    imgZoom.alt = p.alt;
    compteur.textContent = `${indexActuel + 1} / ${photosTab.length}`;
  }

  function ouvrirZoom(index) {
    if (!photosTab.length) return;
    indexActuel = index;
    majLightbox();
    lightbox.classList.add("actif");
    document.body.style.overflow = "hidden";
  }

  function fermerZoom() {
    lightbox.classList.remove("actif");
    document.body.style.overflow = "";
  }

  function photoSuivante(e) {
    if (e) e.stopPropagation();
    indexActuel = (indexActuel + 1) % photosTab.length;
    majLightbox();
  }

  function photoPrecedente(e) {
    if (e) e.stopPropagation();
    indexActuel = (indexActuel - 1 + photosTab.length) % photosTab.length;
    majLightbox();
  }

  // Fermer en cliquant sur le fond (pas sur le contenu)
  lightbox.addEventListener("click", fermerZoom);
  lightbox.querySelector(".lb-contenu").addEventListener("click", (e) => e.stopPropagation());

  // Boutons nav et fermeture
  btnClose.addEventListener("click", fermerZoom);
  btnNext.addEventListener("click", photoSuivante);
  btnPrev.addEventListener("click", photoPrecedente);

  // Navigation clavier
  document.addEventListener("keydown", (e) => {
    if (!lightbox.classList.contains("actif")) return;
    if (e.key === "ArrowRight") photoSuivante(e);
    if (e.key === "ArrowLeft")  photoPrecedente(e);
    if (e.key === "Escape")     fermerZoom();
  });
</script>
