{# Timer JS #}
<script>
  const DEBUT = new Date("{{ evenement.dateDebut }}").getTime();
  const FIN   = new Date("{{ evenement.dateFin }}").getTime();

  const elTimer = document.getElementById("timer");
  const elLabel = document.getElementById("timer-label");
  const elMaps  = document.getElementById("btn-maps");

  function pad(n) { return String(n).padStart(2, "0"); }

  function maj() {
    const now = Date.now();

    if (now > FIN) {
      elLabel.style.display = "none";
      elMaps.style.display  = "none";
      elTimer.innerHTML = '<p class="fini-msg">✨ Merci de votre visite !<br><span style="font-size:1.2rem;opacity:0.8">À très vite.</span></p>';
      clearInterval(intervalle);
      return;
    }

    if (now >= DEBUT) {
      elLabel.style.display = "none";
      elMaps.style.display  = "inline-flex";
      elTimer.innerHTML = '<p class="fini-msg">🌸 Le salon est ouvert !<br><span style="font-size:1.2rem;opacity:0.8">Nous vous attendons jusqu\'à 18h</span></p>';
      clearInterval(intervalle);
      return;
    }

    const d = DEBUT - now;
    document.getElementById("jours").textContent    = pad(Math.floor(d / 86400000));
    document.getElementById("heures").textContent   = pad(Math.floor((d % 86400000) / 3600000));
    document.getElementById("minutes").textContent  = pad(Math.floor((d % 3600000) / 60000));
    document.getElementById("secondes").textContent = pad(Math.floor((d % 60000) / 1000));
    elMaps.style.display = "inline-flex";
  }

  const intervalle = setInterval(maj, 1000);
  maj();
</script>
