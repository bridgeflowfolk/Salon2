---
layout: base.njk
permalink: /tombola/

title: "Tombola — Salon Bien-Être et Créateurs 2026"
description: "Grande tombola solidaire au profit de la Ligue contre le Cancer. 2850 € de lots, plus de 60 cadeaux. Ticket à 2 €. Tirage dimanche 5 avril à 16h30."

hero:
  tag:       "Bien-Être et Créateurs · 4 & 5 Avril 2026"
  titre:     "Grande"
  titreEm:   "Tombola"
  sousTitre: "Au profit de la Ligue contre le Cancer"

total:
  montant: "2 850 €"
  label:   "de lots à gagner · Plus de 60 lots"

lien_helloasso: "https://www.helloasso.com/associations/bridge-and-flow-folk/evenements/tombola"

podium:
  - rang:  "1er lot"
    emoji: "🛁"
    titre: "Nuitée + Spa + Brunch"
    desc:  "Nuitée bien-être et spa pour se ressourcer pleinement"
    valeur: "175 €"
    classe: "premier"
  - rang:  "2e lot"
    emoji: "🚗"
    titre: "Nettoyage Premium"
    desc:  "Nettoyage intérieur et extérieur de votre véhicule"
    valeur: "150 €"
    classe: "deuxieme"
  - rang:  "3e lot"
    emoji: "🌿"
    titre: "Cocooning + Brunch + Bain"
    desc:  "Expérience détente avec bain nordique pour 2 personnes"
    valeur: "110 €"
    classe: "troisieme"

autres_lots:
  - "💆 Massages"
  - "🎁 Bons cadeaux"
  - "💎 Bijoux"
  - "🕯️ Bougies"
  - "🧴 Soins bien-être"
  - "🌿 Produits naturels"
  - "📚 Livres"
  - "🎨 Créations artisanales"
  - "& bien d'autres surprises !"

tirage:
  date:   "Dimanche 5 Avril · 16h30"
  lieu:   "Tirage de clôture · Salle de la Ferme"
  ticket: "🎟️ Ticket à 2 €"
  cause:  "🎗️ Au profit de la Ligue contre le Cancer (Eure-et-Loir)"

pageStyles: |
  .tombola-total { text-align: center; margin-bottom: 2.5rem; opacity: 0; animation: glisser-haut 0.7s ease forwards 0.4s; }
  .montant { font-family: 'Cormorant Garamond', serif; font-size: clamp(3rem,10vw,6rem); font-weight: 300; color: var(--or); line-height: 1; }
  .montant-label { font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--terre); display: block; margin-top: 0.3rem; }
  .lots-podium { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; margin-bottom: 2rem; opacity: 0; animation: glisser-haut 0.7s ease forwards 0.6s; }
  .lot-carte { background: rgba(255,255,255,0.55); border: 1px solid rgba(201,169,110,0.3); border-radius: 16px; padding: 1.5rem 1rem; text-align: center; backdrop-filter: blur(8px); position: relative; overflow: hidden; transition: transform 0.3s, box-shadow 0.3s; }
  .lot-carte:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(160,132,92,0.2); }
  .lot-carte::before { content: ''; position: absolute; top: 0; left: 0; right: 0; }
  .lot-carte.premier::before  { background: linear-gradient(to right,#c9a96e,#e8d090,#c9a96e); height: 4px; }
  .lot-carte.deuxieme::before { background: linear-gradient(to right,#a8a8b8,#d0d0e0,#a8a8b8); height: 3px; }
  .lot-carte.troisieme::before{ background: linear-gradient(to right,#c87941,#e09060,#c87941); height: 3px; }
  .lot-rang { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 0.9rem; color: var(--terre); margin-bottom: 0.3rem; display: block; }
  .lot-emoji { font-size: 2rem; margin: 0.5rem 0; display: block; }
  .lot-titre { font-family: 'Cormorant Garamond', serif; font-weight: 600; font-size: 1rem; color: var(--nuit); margin-bottom: 0.5rem; line-height: 1.3; }
  .lot-desc { font-size: 0.62rem; letter-spacing: 0.05em; color: rgba(44,44,58,0.6); line-height: 1.5; margin-bottom: 0.8rem; }
  .lot-valeur { display: inline-block; background: linear-gradient(135deg,rgba(201,169,110,0.2),rgba(201,120,138,0.15)); border: 1px solid rgba(201,169,110,0.5); font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; color: var(--or); padding: 0.3rem 1rem; border-radius: 100px; }
  .autres-lots { background: rgba(255,255,255,0.55); border: 1px solid rgba(201,169,110,0.3); border-radius: 16px; padding: 2rem; backdrop-filter: blur(8px); margin-bottom: 2rem; opacity: 0; animation: glisser-haut 0.7s ease forwards 0.8s; position: relative; overflow: hidden; }
  .autres-lots::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(to right, var(--sauge), var(--or), var(--lotus)); }
  .autres-titre { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 300; color: var(--nuit); margin-bottom: 1rem; text-align: center; }
  .autres-liste { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; }
  .autres-tag { font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.4rem 1rem; border-radius: 100px; border: 1px solid rgba(160,132,92,0.3); color: var(--terre); background: rgba(255,255,255,0.4); }
  .badge-tombola { display: inline-flex; align-items: center; gap: 8px; background: linear-gradient(135deg, var(--sauge), #5a8e5e); color: #fff; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; padding: 0.5rem 1.5rem; border-radius: 100px; margin-bottom: 2rem; opacity: 0; animation: glisser-haut 0.8s ease forwards 0.5s; cursor: pointer; text-decoration: none; }
  .tirage-bloc { background: linear-gradient(135deg,rgba(122,158,126,0.15),rgba(44,44,58,0.05)); border: 1px solid rgba(122,158,126,0.3); border-radius: 16px; padding: 2rem; text-align: center; margin-bottom: 2rem; opacity: 0; animation: glisser-haut 0.7s ease forwards 1s; }
  .tirage-heure { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem,6vw,3.5rem); font-weight: 300; color: var(--sauge); }
  .tirage-label { font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--sauge); margin-top: 0.3rem; display: block; }
  .ticket-prix { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: var(--terre); margin-top: 0.8rem; }
  .cancer-badge { display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 1rem; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--lotus); padding: 0.5rem 1.2rem; border: 1px solid rgba(201,120,138,0.3); border-radius: 100px; }
  .footer-bloc { text-align: center; opacity: 0; animation: glisser-haut 0.8s ease forwards 1.1s; }
  @media(max-width: 520px) { .lots-podium { grid-template-columns: 1fr; } }
---

{# Hero #}
<div class="hero anime" style="animation-delay:0.2s">
  <span class="hero-tag">{{ hero.tag }}</span>
  <h1>{{ hero.titre }}<br><em>{{ hero.titreEm }}</em></h1>
  <p class="hero-sub">{{ hero.sousTitre }}</p>
</div>

<div style="text-align:center">
  <a href="{{ lien_helloasso }}" target="_blank" rel="noopener noreferrer" class="badge-tombola">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/>
      <line x1="13" y1="5" x2="13" y2="19"/>
    </svg>
    Participer en ligne à notre tombola solidaire
  </a>
</div>

<div class="tombola-total">
  <div class="montant">{{ total.montant }}</div>
  <span class="montant-label">{{ total.label }}</span>
</div>

<div class="sep">
  <div class="sep-l"></div><div class="sep-d"></div>
  <div class="sep-d" style="background:var(--lotus)"></div>
  <div class="sep-d"></div><div class="sep-r"></div>
</div>

{# Top 3 #}
<div class="lots-podium">
  {% for lot in podium %}
  <div class="lot-carte {{ lot.classe }}">
    <span class="lot-rang">{{ lot.rang }}</span>
    <span class="lot-emoji">{{ lot.emoji }}</span>
    <div class="lot-titre">{{ lot.titre }}</div>
    <div class="lot-desc">{{ lot.desc }}</div>
    <span class="lot-valeur">{{ lot.valeur }}</span>
  </div>
  {% endfor %}
</div>

{# Autres lots #}
<div class="autres-lots">
  <div class="autres-titre">Et plus de 60 autres lots…</div>
  <div class="autres-liste">
    {% for tag in autres_lots %}
    <span class="autres-tag">{{ tag }}</span>
    {% endfor %}
  </div>
</div>

{# Tirage #}
<div class="tirage-bloc">
  <div class="tirage-heure">{{ tirage.date }}</div>
  <span class="tirage-label">{{ tirage.lieu }}</span>
  <div class="ticket-prix">{{ tirage.ticket }}</div>
  <div class="cancer-badge">{{ tirage.cause }}</div>
</div>

{# Footer #}
<div class="footer-bloc">
  <a class="fb-lien" href="https://www.facebook.com/people/Bridge-Flow-Folk-BFF/61587252715739/" target="_blank" rel="noopener noreferrer">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
    Suivre Bridge &amp; Flow Folk
  </a>
  <footer>© 2026 Bridge &amp; Flow Folk · Nogent-le-Roi (28) · 06 18 29 18 73</footer>
</div>
